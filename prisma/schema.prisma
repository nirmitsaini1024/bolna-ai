generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SttProvider {
  DEEPGRAM
  SARVAM
}

model Agent {
  id               String   @id @default(uuid())
  organizationId   String?

  name             String
  systemPrompt     String
  welcomeMessage   String?

  llmModel         String?
  temperature      Float?   @default(0.3)
  maxTokens        Int?

  sttProvider      SttProvider @default(DEEPGRAM)
  sttModel         String?
  language         String?

  ttsProvider      String?
  voice            String?
  speechRate       Float?
  stability        Float?
  similarityBoost  Float?
  styleExaggeration Float?

  interruptWords   Int?
  responseLatency  Int?
  endpointingMs    Int?

  silenceTimeout   Int?
  maxCallDuration  Int?
  finalCallMessage String?

  telephonyProvider String?

  noiseCancellation  Boolean @default(false)
  voicemailDetection Boolean @default(false)
  autoReschedule     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  phoneNumbers       PhoneNumber[]
  knowledgeDocuments KnowledgeDocument[]
  tools              Tool[]

  organization Organization? @relation(fields: [organizationId], references: [id])
}

model PhoneNumber {
  id          String @id @default(uuid())
  phoneNumber String @unique
  agentId     String
  agent       Agent  @relation(fields: [agentId], references: [id])
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  organizationId String?
  agentId   String
  content   String
  embedding Float[]
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
}

model Tool {
  id          String   @id @default(uuid())
  organizationId String?
  agentId     String
  name        String
  description String
  parameters  Json
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
}

model Call {
  id        String   @id @default(uuid())
  callSid   String   @unique
  agentId   String?
  organizationId String?
  customerId String?
  phone     String
  startedAt DateTime
  endedAt   DateTime?
  durationMs Int?
  createdAt DateTime @default(now())

  messages   Message[]
  toolEvents ToolEvent[]

  customer Customer? @relation(fields: [customerId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
}

model Customer {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  createdAt DateTime @default(now())

  calls     Call[]
  notes     CustomerNote[]
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  content    String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  callId    String
  role      String
  content   String
  confidence Float?
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id])
}

model ToolEvent {
  id        String   @id @default(uuid())
  callId    String
  toolName  String
  arguments Json
  result    Json
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id])
}

model UsageRecord {
  id             String   @id @default(uuid())
  organizationId String
  type           String
  quantity       Float
  createdAt      DateTime @default(now())
}

model OutboundCall {
  id        String   @id @default(uuid())
  phone     String
  agentId   String?
  status    String   @default("initiated")
  callSid   String?
  createdAt DateTime @default(now())
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  agents    Agent[]
  calls     Call[]
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  role           String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
}
